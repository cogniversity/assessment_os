IMAGE_TAG=latest
HTTP_PORT=80

POSTGRES_USER=assessment
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=assessment_os
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PUBLISH_PORT=5432

SESSION_SECRET=your-long-random-session-secret
CLIENT_URL=http://localhost
SERVER_URL=http://localhost
# Optional nginx subpath (no slashes), e.g. growth → app at http://localhost/growth/
CONTEXT_ROOT=

OIDC_ISSUER=https://your-region.appid.cloud.ibm.com/oauth/v4/your-tenant-id
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_CALLBACK_URL=http://localhost/api/auth/callback

ADMIN_EMAILS=admin@example.com
CAPABILITY_MANAGER_EMAILS=manager@example.com

APPID_IAM_APIKEY=your-ibm-cloud-api-key
APPID_TENANT_ID=your-appid-tenant-id
APPID_MANAGEMENT_URL=https://us-east.appid.cloud.ibm.com
APPID_CD_IDENTITY_FIELD=email
APPID_EXPORT_SECRET=your-appid-export-secret

RUN_DB_SEED=true
DB_RESET_ON_START=false
DEV_AUTH_ENABLED=false
SESSION_COOKIE_SECURE=false
